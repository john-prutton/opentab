{
	"name": "@repo/domain",
	"type": "module",
	"scripts": {
		"dev": "nodemon --watch src --ext ts --exec \"clear && pnpm clean && pnpm build\"",
		"build": "pnpm tsc && pnpm tsc-alias",
		"test": "vitest run || true",
		"clean": "rm -rf dist/*",
		"lint": "eslint"
	},
	"exports": {
		"./*.js": {
			"import": "./dist/*.js",
			"types": "./dist/*.d.ts"
		},
		"./*": {
			"import": "./dist/*/index.js",
			"types": "./dist/*/index.d.ts"
		}
	},
	"devDependencies": {
		"@repo/eslint": "workspace:^",
		"@repo/typescript": "workspace:^",
		"@repo/vitest": "workspace:^"
	},
	"dependencies": {
		"effect": "4.0.0-beta.30"
	}
}
